import sys

input = sys.stdin.read
data = input().split()

n = int(data[0])
members = []

# 데이터를 (나이, 이름) 튜플 형태로 리스트에 저장
for i in range(n):
    age = int(data[i*2 + 1])
    name = data[i*2 + 2]
    members.append((age, name))

# 나이(x[0])를 기준으로 정렬
members.sort(key=lambda x: x[0])

for member in members:
    print(member[0], member[1])
