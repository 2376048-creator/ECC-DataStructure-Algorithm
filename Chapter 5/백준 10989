import sys

# 입력 개수 N 받기
n = int(sys.stdin.readline())

check = [0] * 10001

# 입력을 하나씩 읽으면서 즉시 카운트 (리스트에 저장하지 않음)
for _ in range(n):
    num = int(sys.stdin.readline())
    check[num] += 1

# 카운팅 보드를 돌며 값이 있는 인덱스를 그 횟수만큼 출력
for i in range(10001):
    if check[i] != 0:
        for _ in range(check[i]):
            print(i)
